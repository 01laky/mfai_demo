# Copy to .env in repo root (gitignored). Used by docker-compose.dev.yml for ai-demo-dev.

# Model (weights cached under .data/huggingface on the host)
MFAI_AI_MODEL_NAME=Qwen/Qwen3-1.7B
# After first successful run, set to 1 to load only from cache (no Hugging Face re-download):
MFAI_LOCAL_FILES_ONLY=0

# NVIDIA GPU build (use .../whl/cpu if no GPU)
MFAI_PYTORCH_INDEX=https://download.pytorch.org/whl/cu124

# Resources (WSL .wslconfig should allow enough RAM for mem_limit)
MFAI_CONTAINER_CPUS=12
MFAI_CONTAINER_MEM_RESERVATION=12g
MFAI_CONTAINER_MEM_LIMIT=12g
MFAI_CONTAINER_SHM_SIZE=2gb
MFAI_FAST_GENERATION=1

# --- Mac dev stack → Windows AI worker (same Wi‑Fi / hotspot) ---
# Mac *host* grpcurl to http://<WINDOWS_WIFI_IP>:50051 usually works.
# Mac *Docker* (be-demo-dev) often cannot reach LAN IPs directly (Docker Desktop VM).
# Workaround on Mac: relay on the host, then point BE at host.docker.internal:
#   socat TCP-LISTEN:50051,fork,reuseaddr TCP:<WINDOWS_WIFI_IP>:50051 &
#   export AI_SERVICE_GRPC_ADDRESS=http://host.docker.internal:50051
# Windows: run scripts/windows-ai-firewall.ps1 as Administrator (TCP 50051; ping optional).
# Ping to Windows may fail even when gRPC works (ICMP blocked by default).
