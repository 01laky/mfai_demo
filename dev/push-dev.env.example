# Copy to the monorepo root as `.env` (or `source` / export before `./scripts/start-all-dev.sh`).
# Firebase Console → Project settings → Service accounts → Generate new private key.
# Save the JSON as: many_faces_push/firebase-sa.json   (gitignored; start-all-dev picks it up automatically)

ENABLE_PUSH_WORKER=1

# Optional: same value on worker (PUSH_WORKER_EXPECTED_TOKEN) and API (PUSH_DEV_WORKER_AUTH_TOKEN is set from this by start-all-dev.sh)
# PUSH_WORKER_EXPECTED_TOKEN=dev-push-shared-secret

# Default URL is http://push-worker-dev:50053 (plaintext). For TLS/mTLS use https:// and set the paths below (see docs/guides/push-grpc-tls-mtls.md).
# Copy these into the monorepo root `.env` so docker-compose.dev.yml can substitute ${PUSH_DEV_*}.
# PUSH_DEV_WORKER_GRPC_URL=https://push-worker-dev:50053
# PUSH_DEV_WORKER_TLS_SERVER_CA_PATH=/absolute/path/to/ca.pem
# PUSH_DEV_WORKER_TLS_CLIENT_CERT_PATH=/absolute/path/to/client.crt
# PUSH_DEV_WORKER_TLS_CLIENT_KEY_PATH=/absolute/path/to/client.key
# PUSH_DEV_WORKER_GRPC_TLS_SERVER_NAME=push-worker-dev

# Only if the JSON is not at many_faces_push/firebase-sa.json:
# FIREBASE_SA_HOST_PATH=/absolute/path/to/firebase-adminsdk-xxxxx.json
