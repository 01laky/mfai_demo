# Copy to the monorepo root as `.env` (or `source` / export before `./scripts/start-all-dev.sh`).
# Firebase Console → Project settings → Service accounts → Generate new private key.
# Save the JSON as: many_faces_push/firebase-sa.json   (gitignored; start-all-dev picks it up automatically)

ENABLE_PUSH_WORKER=1

# Optional: same value on worker (PUSH_WORKER_EXPECTED_TOKEN) and API (PUSH_DEV_WORKER_AUTH_TOKEN is set from this by start-all-dev.sh)
# PUSH_WORKER_EXPECTED_TOKEN=dev-push-shared-secret

# Only if the JSON is not at many_faces_push/firebase-sa.json:
# FIREBASE_SA_HOST_PATH=/absolute/path/to/firebase-adminsdk-xxxxx.json
