# Example exports for root docker-compose.dev.yml (mailer worker is on by default in ./scripts/start-all-dev.sh; set ENABLE_MAILER_WORKER=0 to skip).
# Copy to a gitignored file and `source` it before `docker compose up` if you do not use start-all-dev.sh.

export MAIL_DEV_ENABLED=true
export MAIL_DEV_WORKER_GRPC_URL=http://mailer-worker-dev:50054
# export MAIL_DEV_WORKER_AUTH_TOKEN=same-as-MAILER_WORKER_EXPECTED_TOKEN
